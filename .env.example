# TerminAI server port.
PORT=3000

# Root directory exposed to the terminal and file manager APIs.
# Defaults to the repository working directory when unset.
# TERMINAI_WORKSPACE_ROOT=/absolute/path/to/workspace

# Local shell command guardrails.
TERMINAI_COMMAND_TIMEOUT_MS=30000
TERMINAI_COMMAND_MAX_BUFFER=1048576

# Preferred optional AI route: OpenRouter.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# Fallback optional AI route: direct Gemini.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
