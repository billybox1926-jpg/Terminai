# TerminAI environment configuration.
# Copy this file to .env.local and fill in values as needed.

# Server port. Defaults to 3000.
PORT=3000

# Root directory exposed to the terminal and file manager APIs.
# Defaults to the repository working directory when unset.
# TERMINAI_WORKSPACE_ROOT=/absolute/path/to/workspace

# Command execution guardrails.
TERMINAI_COMMAND_TIMEOUT_MS=30000
TERMINAI_COMMAND_MAX_BUFFER=1048576

# Auto-bootstrap: automatically install missing baseline packages on startup.
# Set to "true" to enable. Default is "false" (safe mode: check only, prompt user).
TERMINAI_AUTO_BOOTSTRAP=false

# Package manager override. Set to apt or pkg to force a specific manager.
# When unset, TerminAI auto-detects based on environment.
# PKG_MANAGER=apt

# AI provider: OpenRouter (preferred) or Gemini (fallback).
# At least one provider key is required for the AI Optimizer.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# Fallback direct Gemini route.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
